    "react-router-dom": "^7.18.1",
    "recharts": "^3.10.0",
    "tailwind-merge": "^3.6.0",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "prisma": {
    "schema": "backend/prisma/schema.prisma",
