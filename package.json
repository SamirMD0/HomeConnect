{
  "name": "home-connect",
  "version": "1.0.0",
  "main": "dist/desktop/src/index.js",
  "scripts": {
    "dev:vite": "vite frontend",
    "dev:server": "nodemon --watch backend/src -e ts --exec tsx backend/src/index.ts",
    "dev:electron": "tsc -p tsconfig.server.json && electron .",
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:server\"",
    "build": "vite build frontend && tsc -p tsconfig.server.json",
    "lint": "eslint frontend/src backend/src desktop/src --ext ts,tsx",
    "format": "prettier --write \"{frontend,backend,desktop}/src/**/*.{ts,tsx,css}\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "autoprefixer": "^10.5.4",
    "concurrently": "^10.0.3",
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "eslint": "^8.57.0",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.22",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.5"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@prisma/client": "^5.22.0",
    "@tailwindcss/postcss": "^4.3.3",
    "@tanstack/react-query": "^5.101.4",
    "axios": "^1.18.1",
    "bcrypt": "^6.0.0",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "framer-motion": "^12.42.2",
    "helmet": "^8.3.0",
