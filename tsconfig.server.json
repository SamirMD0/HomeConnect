{
  "compilerOptions": {
    "composite": true,
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "./dist/server",
    "rootDir": ".",
    "paths": {
      "@backend/*": ["./backend/src/*"],
      "@desktop/*": ["./desktop/src/*"]
    }
  },
  "include": ["backend/src", "desktop/src"]
}
